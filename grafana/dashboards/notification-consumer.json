        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max(up{job=\"notification_consumer\"}) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
