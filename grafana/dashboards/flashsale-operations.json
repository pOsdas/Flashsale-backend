      "title": "P95 Latency by Subsystem",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[$__rate_interval])) by (le))",
          "legendFormat": "API",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(outbox_event_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "outbox",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(monitoring_target_processing_duration_seconds_bucket[$__rate_interval])) by (le))",
