    {
      "id": 18,
      "type": "timeseries",
      "title": "Cache Efficiency",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "100 * sum(rate(monitoring_product_cache_lookups_total{result=\"hit\"}[$__rate_interval])) / clamp_min(sum(rate(monitoring_product_cache_lookups_total[$__rate_interval])), 0.000001)",
          "legendFormat": "hit ratio %",
          "refId": "A"
