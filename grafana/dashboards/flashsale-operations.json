          "legendFormat": "notification",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(go_fetcher_product_fetch_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "go fetcher",
          "refId": "E"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ozon_browser_task_execution_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "ozon browser",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
