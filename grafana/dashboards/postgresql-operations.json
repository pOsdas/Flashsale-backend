          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_bgwriter_buffers_backend[5m])",
          "legendFormat": "backend/sec",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 4 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}