{
  "uid": "postgresql-operations",
  "title": "PostgreSQL Operations",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "tags": [
    "flashsale",
    "postgresql",
    "database"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
