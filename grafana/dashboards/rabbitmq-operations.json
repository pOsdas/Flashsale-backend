        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(rabbitmq_global_messages_published_total[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "published"
        },
        {
          "expr": "sum(rate(rabbitmq_global_messages_delivered_consume_manual_ack_total[$__rate_interval]))",
          "refId": "B",
          "legendFormat": "delivered manual ack"
        },
        {
          "expr": "sum(rate(rabbitmq_global_messages_delivered_consume_auto_ack_total[$__rate_interval]))",
          "refId": "C",
          "legendFormat": "delivered auto ack"
