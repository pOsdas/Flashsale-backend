      "title": "Redis TCP Probe",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "max(probe_success{job=\"blackbox_tcp\",instance=\"redis:6379\"}) or vector(0)",
