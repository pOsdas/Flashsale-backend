      "id": 14,
      "type": "logs",
      "title": "Recent Platform Errors",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{compose_service=~\"prometheus|grafana|loki|promtail|cadvisor|blackbox_exporter|redis_exporter|postgres_exporter\"} |~ \"(?i)error|fail|panic\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
