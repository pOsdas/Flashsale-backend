    {
      "id": 6,
      "type": "stat",
      "title": "Containers Not Seen 60s",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(\n  (\n    time()\n    -\n    max by (container_label_com_docker_compose_service) (\n      container_last_seen{\n        container_label_com_docker_compose_project=\"flashsale-backend\",\n        container_label_com_docker_compose_service!=\"\"\n      }\n    )\n  ) > bool 60\n)\nor vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
