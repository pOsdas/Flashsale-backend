        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(telegram_polling_requests_total[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{status}}"
