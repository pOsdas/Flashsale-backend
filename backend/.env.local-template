# # ENV
ENV=dev
APP_ENV=local

# # POSTGRES
POSTGRES_DB=flashsale
POSTGRES_USER=user
POSTGRES_PASSWORD=pwd
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# # BACKEND
DEBUG=True
ENABLE_HTTPS_REDIRECT=False
SECRET_KEY=your-secret-key
ALLOWED_HOSTS=["0.0.0.0","127.0.0.1","localhost","host.docker.internal"]
FETCHER_API_KEY=test-fetcher-key
DJANGO_SETTINGS_MODULE=app_project.settings
OUTBOX_METRICS_PORT=9100
LOG_FORMAT=json

MONITORING_SCANNER_BATCH_SIZE=50
MONITORING_SCANNER_SLEEP_SECONDS=30
MONITORING_SCANNER_METRICS_PORT=8012
MONITORING_SCANNER_OVERDUE_AFTER_SECONDS=300

# # INFRA
GRAFANA_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
GRAFANA_TELEGRAM_CHAT_ID=your-chat-id

MONITORING_FETCHER_MODE=http
GO_FETCHER_BASE_URL=http://127.0.0.1:8090
GO_FETCHER_PARSER_HEALTH_ENDPOINT=/api/v1/parser/health/
GO_FETCHER_PRODUCT_ENDPOINT=/api/v1/fetch/product/
GO_FETCHER_API_KEY=test-fetcher-key
GO_FETCHER_TIMEOUT_SECONDS=20

# # NOTIFICATIONS
NOTIF_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NOTIF_TELEGRAM_BOT_USERNAME=bot_username_without_@

NOTIF_TELEGRAM_CONNECT_TOKEN_MAX_AGE_SECONDS=900
NOTIF_TELEGRAM_CONNECT_SIGNING_SALT='flashsale-notif-tg-connect-CHANGE-ME-LONG-RANDOM-VALUE'

# Общий лимит ответов бота
NOTIF_TELEGRAM_REPLY_RATE_LIMIT_LIMIT=5
NOTIF_TELEGRAM_REPLY_RATE_LIMIT_WINDOW_SECONDS=60

# Preview товара
NOTIF_TELEGRAM_PREVIEW_RATE_LIMIT_LIMIT=5
NOTIF_TELEGRAM_PREVIEW_RATE_LIMIT_WINDOW_SECONDS=60

# Ручная проверка товара
NOTIF_TELEGRAM_CHECK_NOW_RATE_LIMIT_LIMIT=3
NOTIF_TELEGRAM_CHECK_NOW_RATE_LIMIT_WINDOW_SECONDS=60

# Inline callback-кнопки
NOTIF_TELEGRAM_CALLBACK_RATE_LIMIT_LIMIT=30
NOTIF_TELEGRAM_CALLBACK_RATE_LIMIT_WINDOW_SECONDS=60

NOTIF_TELEGRAM_METRICS_PORT=8013

# Polling
NOTIF_TELEGRAM_DROP_PENDING_UPDATES_ON_START=False

# Pending product confirmation
NOTIF_TELEGRAM_PENDING_PRODUCT_TTL_SECONDS=600
NOTIF_TELEGRAM_PENDING_PRODUCT_LOCK_SECONDS=30

NOTIFICATION_CONSUMER_METRICS_PORT=8011
NOTIFICATION_RABBITMQ_QUEUE=flashsale.notifications
NOTIFICATION_RABBITMQ_DLQ=flashsale.notifications.dlq
NOTIFICATION_RABBITMQ_DLX=flashsale.notifications.dlx
NOTIFICATION_RABBITMQ_PREFETCH_COUNT=10
NOTIFICATION_RABBITMQ_ROUTING_KEYS=alert.created

# # RABBITMQ
OUTBOX_DISPATCH_MODE=local  # local / rabbitmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=flashsale.events

# # REDIS / CELERY
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# # ensure_db
ALLOW_DB_CREATE=1
POSTGRES_MAINTENANCE_DB=postgres
DB_CREATE_RETRIES=10
DB_CREATE_RETRY_DELAY=2