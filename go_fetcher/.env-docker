DJANGO_URL=http://host.docker.internal:8000

FETCHER_API_KEY=test-fetcher-key

WB_REQUEST_DELAY_MS=700
WB_MAX_RETRIES=3
WB_RETRY_BASE_DELAY_MS=1000
WB_BROWSER_FETCHER_URL=http://wb_browser_fetcher:8096
WB_BROWSER_FETCHER_ENABLED=true
WB_BROWSER_FETCHER_TIMEOUT_SECONDS=35

OZON_REQUEST_DELAY_MS=700
OZON_MAX_RETRIES=3
OZON_RETRY_BASE_DELAY_MS=1000
OZON_HTTP_PARSER_TIMEOUT_SECONDS=12

OZON_BROWSER_FETCHER_URL=http://ozon_browser_fetcher:8095
OZON_BROWSER_FETCHER_ENABLED=true
OZON_BROWSER_FETCHER_TIMEOUT_SECONDS=35

# Browser fetcher containers start Google Chrome Stable as an external process
# and connect Playwright to it over CDP. Both containers use 9222 internally;
# the CDP port is not published outside the container.
BROWSER_CDP_HOST=127.0.0.1
BROWSER_CDP_PORT=9222
BROWSER_DISPLAY=:99
BROWSER_WINDOW_SIZE=1400,900
BROWSER_LANGUAGE=ru-RU
TZ=Europe/Moscow
BROWSER_START_TIMEOUT_SECONDS=90
BROWSER_RUNTIME_DIR=/tmp/browser-runtime
BROWSER_PROFILE_DIR=/data/browser-profile
BROWSER_DISABLE_SANDBOX=false
BROWSER_DISABLE_DEV_SHM_USAGE=false

# Optional proxy accepted by Chrome. For an authenticated proxy, credentials
# may require a separate authentication mechanism; do not assume that
# user:password@host:port works in every Chrome build.
BROWSER_PROXY_SERVER=
BROWSER_PROXY_BYPASS_LIST=
BROWSER_EXTRA_ARGS=

OZON_BROWSER_CDP_URL=
OZON_BROWSER_CDP_CONNECT_TIMEOUT_MS=15000
OZON_BROWSER_CDP_START_TIMEOUT_SECONDS=90
OZON_BROWSER_CDP_RETRY_DELAY_SECONDS=1
OZON_BROWSER_ACTION_TIMEOUT_MS=8000
OZON_BROWSER_NAVIGATION_TIMEOUT_MS=45000
OZON_BROWSER_CHALLENGE_TIMEOUT_MS=25000
OZON_BROWSER_IMPORT_COOKIE_FILE=true
OZON_BROWSER_COOKIE_IMPORT_EXCLUDE_NAMES=abt_data,__Secure-ETC

WB_BROWSER_CDP_URL=
WB_BROWSER_CDP_CONNECT_TIMEOUT_MS=15000
WB_BROWSER_CDP_START_TIMEOUT_SECONDS=90
WB_BROWSER_CDP_RETRY_DELAY_SECONDS=1
WB_BROWSER_IMPORT_COOKIE_FILE=true
